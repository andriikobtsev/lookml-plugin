<idea-plugin>
    <id>com.andriidev.lookml</id>
    <name>LookML Support</name>
    <vendor email="andrii.kobtsev@gmail.com" url="https://github.com/andriikobtsev/lookml-plugin">Andrii Kobtsev</vendor>

    <!-- release-date = YYYYMMDD of the Marketplace release you upload; update when publishing. -->
    <product-descriptor code="PLOOKMLSUPPORT" release-date="20260421" release-version="20261"/>

    <!-- Compatible with PyCharm and other IntelliJ-based IDEs -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    
    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="com.andriidev.lookml.license" displayType="STICKY_BALLOON" isLogByDefault="true"/>

        <postStartupActivity implementation="com.yourcompany.lookml.license.LookMLLicenseStartupActivity"/>
        <!-- File Type -->
        <fileType 
            name="LookML" 
            implementationClass="com.yourcompany.lookml.LookMLFileType"
            language="LookML" 
            extensions="lkml;lookml"/>
        
        <!-- Language -->
        <lang.parserDefinition 
            language="LookML"
            implementationClass="com.yourcompany.lookml.LookMLParserDefinition"/>
        
        <!-- Syntax Highlighting -->
        <lang.syntaxHighlighterFactory 
            language="LookML"
            implementationClass="com.yourcompany.lookml.highlighting.LookMLSyntaxHighlighterFactory"/>
        
        <!-- Color Settings Page -->
        <colorSettingsPage 
            implementation="com.yourcompany.lookml.highlighting.LookMLColorSettingsPage"/>
        
        <!-- Commenter -->
        <lang.commenter 
            language="LookML"
            implementationClass="com.yourcompany.lookml.LookMLCommenter"/>
        
        <!-- Brace Matcher -->
        <lang.braceMatcher 
            language="LookML"
            implementationClass="com.yourcompany.lookml.LookMLBraceMatcher"/>
        
        <!-- Quote Handler -->
        <lang.quoteHandler 
            language="LookML"
            implementationClass="com.yourcompany.lookml.LookMLQuoteHandler"/>
        
        <!-- Completion -->
        <completion.contributor 
            language="LookML"
            implementationClass="com.yourcompany.lookml.completion.LookMLCompletionContributor"/>
        
        <!-- Code Folding -->
        <lang.foldingBuilder
            language="LookML"
            implementationClass="com.yourcompany.lookml.formatting.LookMLFoldingBuilder"/>

        <!-- Code Formatting -->
        <lang.formatter
            language="LookML"
            implementationClass="com.yourcompany.lookml.formatting.LookMLFormattingModelBuilderV2"/>

        <!-- Code Style Settings -->
        <langCodeStyleSettingsProvider
            implementation="com.yourcompany.lookml.formatting.LookMLLanguageCodeStyleSettingsProvider"/>

        <annotator
            language="LookML"
            implementationClass="com.yourcompany.lookml.yaml.YamlDashboardAnnotator"/>
    </extensions>
    
    <actions>
        <action id="LookML.ReformatYamlDashboard"
                class="com.yourcompany.lookml.actions.ReformatYamlDashboardAction"
                text="Reformat YAML Dashboard"
                description="Reformat YAML dashboard with correct indentation">
            <add-to-group group-id="CodeFormatGroup" anchor="after" relative-to-action="ReformatCode"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift Y"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt shift Y"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt shift Y"/>
        </action>
        
        <action id="LookML.FormatCode"
                class="com.yourcompany.lookml.formatting.LookMLFormatAction"
                text="Format LookML Code"
                description="Format LookML code with proper indentation">
            <add-to-group group-id="CodeFormatGroup" anchor="after" relative-to-action="ReformatCode"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift L"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt shift L"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt shift L"/>
        </action>
    </actions>
</idea-plugin>
